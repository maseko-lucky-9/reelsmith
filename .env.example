# ── Database ──────────────────────────────────────────────────────────────────
# asyncpg URL — matches the docker-compose.yml defaults
YTVIDEO_DB_URL=postgresql+asyncpg://reelsmith:reelsmith@localhost/reelsmith

# "sql"    → Postgres-backed store (production default)
# "memory" → in-memory store (fast unit tests, no DB needed)
YTVIDEO_JOB_STORE=sql

# ── Jobs & concurrency ────────────────────────────────────────────────────────
YTVIDEO_MAX_CONCURRENT_JOBS=1
YTVIDEO_MAX_PARALLEL_CHAPTERS=1
YTVIDEO_MAX_THREAD_WORKERS=4

# ── Pipeline defaults ─────────────────────────────────────────────────────────
YTVIDEO_DEFAULT_DOWNLOAD_PATH=/tmp/yt
YTVIDEO_DEFAULT_CAPTION_FORMAT=srt
YTVIDEO_DEFAULT_TARGET_ASPECT_RATIO=0.5625
YTVIDEO_DEFAULT_TRANSCRIPTION_LANGUAGE=en-US

# ── Transcription ─────────────────────────────────────────────────────────────
# "whisper" → faster-whisper (local GPU/CPU)
# "stub"    → returns empty transcript (tests / CI without GPU)
YTVIDEO_TRANSCRIPTION_PROVIDER=whisper
YTVIDEO_WHISPER_MODEL=base

# ── Segment scoring ───────────────────────────────────────────────────────────
# "local_heuristic" → librosa + VADER + spaCy heuristics (Phase 4)
# "chapter"         → cut on YouTube chapters (current default, fully backwards-compat)
# "stub"            → returns fixed scores (tests)
YTVIDEO_SEGMENT_PROVIDER=chapter
YTVIDEO_TARGET_CLIP_SECONDS_MIN=20
YTVIDEO_TARGET_CLIP_SECONDS_MAX=60
# JSON object of weights (must sum to 1.0)
YTVIDEO_SCORE_WEIGHTS={"hook":0.30,"value":0.25,"emotion":0.15,"audio":0.15,"trend":0.15}

# ── Reframe ───────────────────────────────────────────────────────────────────
# "letterbox" → blur + crop to aspect (current default)
# "face_track" → MediaPipe face tracking (Phase 5)
# "stub"       → no-op (tests)
YTVIDEO_REFRAME_PROVIDER=letterbox

# ── B-Roll ────────────────────────────────────────────────────────────────────
YTVIDEO_BROLL_PROVIDER=none

# ── Media & retention ─────────────────────────────────────────────────────────
YTVIDEO_MAX_UPLOAD_MB=500
YTVIDEO_RETENTION_DAYS=30
YTVIDEO_RETENTION_SWEEP_MINUTES=60

# ── Frontend ──────────────────────────────────────────────────────────────────
# Set to true to have FastAPI serve the built React app at /
YTVIDEO_SERVE_FRONTEND=false

# ── Auth (Phase 8) ────────────────────────────────────────────────────────────
# YTVIDEO_REQUIRE_AUTH=false
# YTVIDEO_API_KEY=<generate with: openssl rand -hex 32>

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins. Defaults to localhost dev origins.
YTVIDEO_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ── Rendering ─────────────────────────────────────────────────────────────────
YTVIDEO_CAPTION_WORDS_PER_SEGMENT=3
YTVIDEO_DOWNLOAD_TIMEOUT_SECONDS=600
YTVIDEO_TRANSCRIPTION_TIMEOUT_SECONDS=120
YTVIDEO_RENDER_TIMEOUT_SECONDS=3600
